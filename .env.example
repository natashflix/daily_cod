# Скопируй этот файл в .env и впиши свой ключ OpenAI.
# Нужен только для уровней 3-5 (там бота защищает настоящая LLM).
# Получить ключ: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...впиши-сюда-свой-ключ

# Модель OpenAI для ботов-охранников (уровни 3-5).
# gpt-4o-mini — дёшево и достаточно умно. gpt-4o — умнее, но дороже.
OPENAI_MODEL=gpt-4o-mini

# Порт, на котором поднимется игра
PORT=3000

# Пароль для страницы /admin.html — защищает просмотр атак участников после игры.
# Придумай любой, впиши сюда и добавь в настройки Railway (Variables).
ADMIN_PASSWORD=придумай-сюда-пароль
